{
  "name": "lycus-score",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "prebuild": "bun run db:migrate",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "format": "prettier --write .",
    "lint": "prettier --check . && eslint .",
    "reinstall": "rm -rf node_modules && rm -rf .svelte-kit && rm -rf .vercel && rm bun.lock && bun install",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "bun run seed.ts"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/js": "^9.36.0",
    "@internationalized/date": "^3.11.0",
    "@lucide/svelte": "^0.560.0",
    "@sveltejs/adapter-vercel": "^6.0.0",
    "@sveltejs/kit": "^2.53.0",
    "@sveltejs/vite-plugin-svelte": "^6.0.0",
    "@tailwindcss/vite": "^4.1.15",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^25",
    "@types/web-push": "^3.6.4",
    "bits-ui": "^2.14.2",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-svelte": "^3.12.5",
    "globals": "^16.0.0",
    "layerchart": "2.0.0-next.48",
    "mode-watcher": "^1.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-svelte": "^3.4.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.3.3",
    "svelte-sonner": "^1.0.6",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.46.2",
    "vite": "^7.1.12",
    "vite-plugin-devtools-json": "^1.0.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@types/ws": "^8.18.1",
    "better-auth": "^1.4.2",
    "drizzle-orm": "^0.45.1",
    "web-push": "^3.6.7",
    "ws": "^8.20.0",
    "zod": "^4.1.12"
  }
}
